{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "linear", "lineWidth": 2, "stacking": { "mode": "normal", "group": "A" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        { "expr": "sum by (service_name) (db_pool_connections_in_use)", "legendFormat": "{{service_name}} in_use", "refId": "A" },
        { "expr": "sum by (service_name) (db_pool_connections_idle)", "legendFormat": "{{service_name}} idle", "refId": "B" }
      ],
      "title": "DB pool connections (in_use + idle stacked)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 } ] },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        { "expr": "sum by (service_name) (db_pool_connections_in_use) / clamp_min(sum by (service_name) (db_pool_connections_open), 1)", "legendFormat": "{{service_name}}", "refId": "A" }
      ],
      "title": "Pool saturation (in_use / open)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "ops" }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        { "expr": "rate(db_pool_acquire_wait_count_total[1m])", "legendFormat": "{{service_name}}", "refId": "A" }
      ],
      "title": "Connection acquire wait rate (per second)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "s" }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        { "expr": "rate(db_pool_acquire_wait_seconds_total[1m])", "legendFormat": "{{service_name}}", "refId": "A" }
      ],
      "title": "Time spent waiting on pool (per second)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["utro", "db"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Utro / Database Pool",
  "uid": "utro-db-pool",
  "version": 1,
  "weekStart": ""
}
