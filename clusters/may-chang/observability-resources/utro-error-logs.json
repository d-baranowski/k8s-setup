    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "lineWidth": 1, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "last"] } },
      "targets": [
        {
          "expr": "sum by (service_name) (count_over_time({namespace=\"default\", service_name=~\"$service\"} | detected_level = `error` [$__interval]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "title": "Error rate by service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
