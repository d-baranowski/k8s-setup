{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Open Tempo Explore",
      "type": "link",
      "url": "/explore?left=%7B%22datasource%22:%22tempo%22,%22queries%22:%5B%7B%22refId%22:%22A%22,%22queryType%22:%22traceqlSearch%22,%22filters%22:%5B%5D%7D%5D%7D",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Service map (last 15m)",
      "type": "nodeGraph",
      "targets": [
        { "queryType": "serviceMap", "refId": "A", "datasource": { "type": "tempo", "uid": "tempo" } }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 1 } ] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 12 },
      "id": 2,
      "options": { "showHeader": true, "sortBy": [ { "displayName": "Value", "desc": true } ] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (client, server, le) (rate(traces_service_graph_request_server_seconds_bucket[5m])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Edge latency p95 (server-side, 5m)",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 }, "unit": "reqps" }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 12 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        {
          "expr": "sum by (client, server) (rate(traces_service_graph_request_total[1m]))",
          "legendFormat": "{{client}} -> {{server}}",
          "refId": "A"
        },
        {
          "expr": "sum by (client, server) (rate(traces_service_graph_request_failed_total[1m]))",
          "legendFormat": "FAIL {{client}} -> {{server}}",
          "refId": "B"
        }
      ],
      "title": "Edge request rate + failures (1m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "spectrum" }, "custom": { "scaleDistribution": { "type": "log", "log": 2 } }, "unit": "s" }
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "id": 4,
      "options": {
        "calculate": false,
        "color": { "mode": "scheme", "scheme": "Spectral", "exponent": 0.5, "fill": "dark-orange", "reverse": false, "scale": "exponential", "steps": 64 },
        "yAxis": { "axisPlacement": "left", "reverse": false, "unit": "ms" }
      },
      "targets": [
        {
          "expr": "sum by (le) (rate(traces_spanmetrics_latency_bucket{service=~\"rpg\\\\..*|utro-ui\", span_kind=\"SPAN_KIND_SERVER\"}[1m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "title": "Root operation latency heatmap (server spans, 1m)",
      "type": "heatmap"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 31 },
      "id": 5,
      "title": "Slowest server-handled traces (last 1h)",
      "description": "Traces that include a SERVER-kind span (i.e. a real RPC or HTTP request that hit gateway or core). Excludes background polling loops in payment which only emit BEGIN/COMMIT.",
      "type": "table",
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View trace in Explore",
                    "url": "/explore?left=%7B%22datasource%22:%22tempo%22,%22queries%22:%5B%7B%22refId%22:%22A%22,%22queryType%22:%22traceql%22,%22query%22:%22${__value.raw}%22%7D%5D%7D",
                    "targetBlank": true
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "filters": [
            { "id": "kind", "operator": "=", "scope": "span", "tag": "kind", "value": "server", "valueType": "keyword" },
            { "id": "duration", "operator": ">", "scope": "intrinsic", "tag": "duration", "value": "50ms", "valueType": "duration" }
          ],
          "limit": 50,
          "tableType": "traces",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 45 },
      "id": 6,
      "title": "UI-rooted traces (browser → backend → DB)",
      "type": "table",
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "traceID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View trace in Explore",
                    "url": "/explore?left=%7B%22datasource%22:%22tempo%22,%22queries%22:%5B%7B%22refId%22:%22A%22,%22queryType%22:%22traceql%22,%22query%22:%22${__value.raw}%22%7D%5D%7D",
                    "targetBlank": true
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "filters": [
            { "id": "service-name", "operator": "=", "scope": "resource", "tag": "service.name", "value": ["utro-ui"], "valueType": "string" }
          ],
          "limit": 50,
          "tableType": "traces",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["utro", "traces", "e2e"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Utro / End-to-End Traces",
  "uid": "utro-traces",
  "version": 1,
  "weekStart": ""
}
